{
  "version": 1,
  "hooks": {
    "beforeSubmitPrompt": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-prompt-context.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-resource-usage.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-template-consistency.ps1"
      }
    ],
    "beforeShellExecution": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-cursor-activity.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-git-commands.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-pre-push.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/block-destructive-shell.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-db-shell-operations.ps1"
      }
    ],
    "preToolUse": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-resource-usage.ps1",
        "matcher": "Read"
      }
    ],
    "subagentStart": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-resource-usage.ps1"
      }
    ],
    "subagentStop": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-resource-usage.ps1"
      }
    ],
    "beforeMCPExecution": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-mcp-operations.ps1"
      }
    ],
    "beforeReadFile": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/redact-sensitive-read.ps1"
      }
    ],
    "afterFileEdit": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-cursor-activity.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/format-after-edit.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/validate-template-consistency.ps1"
      }
    ],
    "stop": [
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-cursor-activity.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/log-resource-usage.ps1"
      },
      {
        "command": "pwsh -NoProfile -ExecutionPolicy Bypass -File .cursor/hooks/scripts/suggest-commit-on-stop.ps1"
      }
    ]
  }
}
