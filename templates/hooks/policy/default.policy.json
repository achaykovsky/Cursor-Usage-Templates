{
  "version": 1,
  "modes": {
    "db_shell": "ask",
    "shell_destructive": "deny",
    "mcp_write": "ask",
    "mcp_unknown": "ask",
    "git_commit_format": "deny",
    "git_commit_unparsed": "allow",
    "git_history_rewrite": "deny",
    "pre_push": "deny"
  },
  "shared_destructive_sql": {
    "deny": [
      {
        "id": "drop_database",
        "pattern": "(?i)\\bdrop\\s+database\\b",
        "apply": ["db_shell", "shell_destructive"]
      },
      {
        "id": "truncate_table",
        "pattern": "(?i)\\btruncate\\s+table\\b",
        "apply": ["db_shell"],
        "db_requires_sql_carrier": true
      },
      {
        "id": "drop_table",
        "pattern": "(?i)\\bdrop\\s+table\\b",
        "apply": ["db_shell"],
        "db_requires_sql_carrier": true
      },
      {
        "id": "drop_table_or_database_bare",
        "pattern": "(?i)DROP\\s+(TABLE|DATABASE)\\s+",
        "apply": ["shell_destructive"]
      },
      {
        "id": "delete_all_rows",
        "pattern": "(?i)\\bdelete\\s+from\\s+\\w+\\s*(?:;|$)",
        "apply": ["db_shell"],
        "db_requires_sql_carrier": true
      },
      {
        "id": "delete_all_rows_bare",
        "pattern": "(?i)DELETE\\s+FROM\\s+\\w+\\s*;?\\s*$",
        "apply": ["shell_destructive"]
      }
    ]
  },
  "db_shell": {
    "require_db_context": true,
    "binaries": [
      "psql", "mysql", "mariadb", "sqlite3", "sqlcmd", "mongosh", "mongo",
      "alembic", "flyway", "liquibase", "dbmate", "prisma", "typeorm", "knex", "sequelize-cli"
    ],
    "deny": [
      { "id": "alembic_downgrade", "pattern": "(?i)\\balembic\\s+downgrade\\s+-1\\b" },
      { "id": "flyway_clean", "pattern": "(?i)\\bflyway\\s+clean\\b" },
      { "id": "liquibase_rollback", "pattern": "(?i)\\bliquibase\\s+rollback\\b" },
      { "id": "prisma_migrate_reset", "pattern": "(?i)\\bprisma\\s+migrate\\s+reset\\b" }
    ],
    "ask": [
      { "id": "sql_delete", "pattern": "(?i)\\bdelete\\s+from\\b", "requires_sql_carrier": true },
      { "id": "sql_update", "pattern": "(?i)\\bupdate\\s+\\w+\\s+set\\b", "requires_sql_carrier": true },
      { "id": "sql_insert", "pattern": "(?i)\\binsert\\s+into\\b", "requires_sql_carrier": true },
      { "id": "sql_alter", "pattern": "(?i)\\balter\\s+table\\b", "requires_sql_carrier": true },
      { "id": "sql_create_table", "pattern": "(?i)\\bcreate\\s+table\\b", "requires_sql_carrier": true },
      { "id": "alembic_upgrade", "argv_contains": ["alembic", "upgrade"] },
      { "id": "alembic_downgrade", "argv_contains": ["alembic", "downgrade"] },
      { "id": "prisma_migrate", "argv_contains": ["prisma", "migrate"] },
      { "id": "flyway_migrate", "argv_contains": ["flyway", "migrate"] },
      { "id": "liquibase_update", "argv_contains": ["liquibase", "update"] },
      { "id": "dbmate_up", "argv_contains": ["dbmate", "up"] }
    ],
    "allow_readonly_sql": [
      { "id": "select", "pattern": "(?i)^\\s*select\\b" },
      { "id": "explain", "pattern": "(?i)^\\s*explain\\b" },
      { "id": "show", "pattern": "(?i)^\\s*show\\b" },
      { "id": "describe", "pattern": "(?i)^\\s*(describe|desc)\\b" }
    ]
  },
  "shell_destructive": {
    "deny": [
      { "id": "rm_rf_root", "pattern": "(?i)rm\\s+-rf\\s+/" },
      { "id": "rm_rf_home", "pattern": "(?i)rm\\s+-rf\\s+\\$" },
      { "id": "fork_bomb", "pattern": ":\\s*\\(\\s*\\)\\s*\\{\\s*:\\s*\\|" }
    ]
  },
  "pre_push": {
    "detect_poetry_pyproject": true,
    "detect_npm_test_script": true,
    "detect_pytest_ini": true
  },
  "git": {
    "protected_branches": ["main", "master"],
    "conventional_commits": true,
    "max_subject_length": 72,
    "min_subject_length": 10,
    "conventional_pattern": "^(feat|fix|chore|docs|refactor|test|style|perf|build|ci)(\\([a-z0-9-]+\\))?!?: .+",
    "history_rewrite_deny": [
      { "id": "rebase", "pattern": "(?i)\\bgit\\s+rebase\\b" },
      { "id": "reset_hard", "pattern": "(?i)\\bgit\\s+reset\\s+--hard\\b" },
      { "id": "amend_pushed", "pattern": "(?i)\\bgit\\s+commit\\b.*--amend\\b" },
      { "id": "force_push", "pattern": "(?i)\\bgit\\s+push\\b.*((^|\\s)-f(\\s|$)|--force(-with-lease)?\\b)" },
      { "id": "filter_history", "pattern": "(?i)\\bgit\\s+(filter-branch|filter-repo)\\b" }
    ],
    "gh_merge_deny_flags": [
      { "id": "squash_merge", "pattern": "(?i)\\bgh\\s+pr\\s+merge\\b.*((^|\\s)-s(\\s|$)|--squash\\b)" },
      { "id": "rebase_merge", "pattern": "(?i)\\bgh\\s+pr\\s+merge\\b.*((^|\\s)-r(\\s|$)|--rebase\\b)" },
      { "id": "delete_branch", "pattern": "(?i)\\bgh\\s+pr\\s+merge\\b.*((^|\\s)-d(\\s|$)|--delete-branch\\b)" }
    ]
  },
  "mcp": {
    "default_unknown_risk": "unknown",
    "db_server_pattern": "(sql|postgres|mysql|database|snowflake|bigquery|databricks)",
    "global_read_prefixes": ["get_", "list_", "fetch_", "search_", "describe_", "show_", "view_"],
    "global_read_contains": ["_get_", "_list_", "_read_", "_fetch_", "_search_", "_describe_", "_show_"],
    "global_write_prefixes": ["create_", "update_", "delete_", "insert_", "drop_", "upsert_", "publish_", "deploy_"],
    "global_write_exact": ["git_push", "git_add_or_commit", "issues_create", "issues_add_comment", "pull_request_create", "pull_request_create_review"],
    "global_write_name_pattern": "(^|[_-])(push|merge|close|assign|comment|tag)($|[_-])"
  }
}
