{
  "schema_version": 1,
  "id": "faq-bot",
  "display_name": "Product FAQ Bot",
  "channels": ["web", "api"],
  "persona": {
    "tone": "friendly, factual",
    "disclosure": "I'm an AI FAQ assistant. Answers are based on our public documentation."
  },
  "model": {
    "provider": "anthropic",
    "name": "claude-sonnet-4",
    "max_tokens_per_turn": 1024
  },
  "tools": [
    { "name": "search_knowledge_base", "risk": "read", "description": "Retrieve FAQ articles" }
  ],
  "escalation": {
    "enabled": true,
    "sla_minutes": 120,
    "channel": "email",
    "triggers": ["user_requests_human", "out_of_scope"]
  },
  "data": {
    "retention_days": 30,
    "store_full_prompts": false
  },
  "rate_limits": {
    "requests_per_minute": 60
  }
}
