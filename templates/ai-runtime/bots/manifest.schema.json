{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-usage-templates/ai-runtime/bots/manifest.schema.json",
  "title": "CustomerBotManifest",
  "type": "object",
  "required": ["schema_version", "id", "channels", "persona", "model", "tools", "escalation"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "display_name": { "type": "string", "maxLength": 128 },
    "channels": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "enum": ["slack", "web", "api"] }
    },
    "persona": {
      "type": "object",
      "required": ["tone", "disclosure"],
      "additionalProperties": false,
      "properties": {
        "tone": { "type": "string", "maxLength": 256 },
        "disclosure": { "type": "string", "maxLength": 512 },
        "system_prompt_ref": { "type": "string", "maxLength": 256 }
      }
    },
    "model": {
      "type": "object",
      "required": ["provider", "name"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "maxLength": 64 },
        "name": { "type": "string", "maxLength": 128 },
        "max_tokens_per_turn": { "type": "integer", "minimum": 1, "maximum": 128000 }
      }
    },
    "tools": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "risk"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
          "risk": { "type": "string", "enum": ["read", "write", "destructive"] },
          "description": { "type": "string", "maxLength": 512 }
        }
      }
    },
    "escalation": {
      "type": "object",
      "required": ["enabled", "sla_minutes"],
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "sla_minutes": { "type": "integer", "minimum": 1, "maximum": 10080 },
        "channel": { "type": "string", "enum": ["slack", "email", "ticket", "api"] },
        "triggers": {
          "type": "array",
          "items": { "type": "string", "maxLength": 128 }
        }
      }
    },
    "data": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "retention_days": { "type": "integer", "minimum": 1, "maximum": 3650 },
        "store_full_prompts": { "type": "boolean" }
      }
    },
    "rate_limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests_per_minute": { "type": "integer", "minimum": 1 },
        "tokens_per_day": { "type": "integer", "minimum": 1 }
      }
    }
  }
}
