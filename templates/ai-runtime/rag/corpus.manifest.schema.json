{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cursor-usage-templates/ai-runtime/rag/corpus.manifest.schema.json",
  "title": "RagCorpusManifest",
  "type": "object",
  "required": ["schema_version", "id", "sources", "chunking", "embedding", "retrieval"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "display_name": { "type": "string", "maxLength": 128 },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["source_id", "type"],
        "additionalProperties": false,
        "properties": {
          "source_id": { "type": "string", "maxLength": 64 },
          "type": { "type": "string", "enum": ["markdown", "html", "pdf", "confluence", "api"] },
          "uri": { "type": "string", "maxLength": 512 },
          "version": { "type": "string", "maxLength": 64 }
        }
      }
    },
    "chunking": {
      "type": "object",
      "required": ["strategy", "max_tokens"],
      "additionalProperties": false,
      "properties": {
        "strategy": { "type": "string", "enum": ["fixed", "semantic", "structure_aware"] },
        "max_tokens": { "type": "integer", "minimum": 64, "maximum": 8192 },
        "overlap_tokens": { "type": "integer", "minimum": 0, "maximum": 1024 }
      }
    },
    "embedding": {
      "type": "object",
      "required": ["provider", "model", "dimensions"],
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "maxLength": 64 },
        "model": { "type": "string", "maxLength": 128 },
        "dimensions": { "type": "integer", "minimum": 1, "maximum": 4096 }
      }
    },
    "retrieval": {
      "type": "object",
      "required": ["top_k", "min_score"],
      "additionalProperties": false,
      "properties": {
        "top_k": { "type": "integer", "minimum": 1, "maximum": 50 },
        "min_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "hybrid": { "type": "boolean" },
        "rerank": { "type": "boolean" }
      }
    },
    "freshness": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sla_hours": { "type": "integer", "minimum": 1 },
        "reindex_on_source_change": { "type": "boolean" }
      }
    },
    "index": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "backend": { "type": "string", "enum": ["pgvector", "pinecone", "weaviate", "opensearch", "chroma"] },
        "namespace": { "type": "string", "maxLength": 128 }
      }
    }
  }
}
