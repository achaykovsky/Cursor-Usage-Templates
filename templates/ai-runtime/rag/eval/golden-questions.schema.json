{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RagGoldenQuestions",
  "type": "object",
  "required": ["schema_version", "corpus_id", "questions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "corpus_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "question"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "maxLength": 64 },
          "question": { "type": "string", "maxLength": 1024 },
          "expected_doc_ids": {
            "type": "array",
            "items": { "type": "string", "maxLength": 128 }
          },
          "must_cite": { "type": "boolean" },
          "must_not_contain": {
            "type": "array",
            "items": { "type": "string", "maxLength": 128 }
          }
        }
      }
    }
  }
}
