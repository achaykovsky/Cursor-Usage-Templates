{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PromptEvalSuite",
  "type": "object",
  "required": ["schema_version", "suite_id", "prompt_id", "cases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "suite_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "prompt_id": { "type": "string", "maxLength": 128 },
    "prompt_version": { "type": "string", "maxLength": 64 },
    "description": { "type": "string", "maxLength": 512 },
    "model": { "type": "string", "maxLength": 128 },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
    "corpus_version": { "type": "string", "maxLength": 64 },
    "pass_threshold": { "type": "number", "minimum": 0, "maximum": 1 },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/case" }
    }
  },
  "$defs": {
    "case": {
      "type": "object",
      "required": ["id", "category", "input", "assertions"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string", "maxLength": 64 },
        "category": {
          "type": "string",
          "enum": [
            "happy_path",
            "edge_case",
            "refusal",
            "adversarial",
            "tool_use",
            "multi_turn"
          ]
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "maxLength": 64 },
          "maxItems": 16
        },
        "prompt_version": { "type": "string", "maxLength": 64 },
        "notes": { "type": "string", "maxLength": 512 },
        "input": { "$ref": "#/$defs/input" },
        "assertions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/assertion" }
        }
      }
    },
    "input": {
      "type": "object",
      "required": ["messages"],
      "additionalProperties": false,
      "properties": {
        "messages": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/message" }
        },
        "context": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "message": {
      "type": "object",
      "required": ["role", "content"],
      "additionalProperties": false,
      "properties": {
        "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
        "content": { "type": "string", "maxLength": 8192 }
      }
    },
    "assertion": {
      "oneOf": [
        { "$ref": "#/$defs/mustContain" },
        { "$ref": "#/$defs/mustNotContain" },
        { "$ref": "#/$defs/regex" },
        { "$ref": "#/$defs/maxLength" },
        { "$ref": "#/$defs/jsonSchema" },
        { "$ref": "#/$defs/toolCall" },
        { "$ref": "#/$defs/refusal" },
        { "$ref": "#/$defs/noPiiPatterns" },
        { "$ref": "#/$defs/llmJudge" }
      ]
    },
    "mustContain": {
      "type": "object",
      "required": ["type", "values"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "must_contain" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "maxLength": 256 }
        }
      }
    },
    "mustNotContain": {
      "type": "object",
      "required": ["type", "values"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "must_not_contain" },
        "values": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "maxLength": 256 }
        }
      }
    },
    "regex": {
      "type": "object",
      "required": ["type", "pattern"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "regex" },
        "pattern": { "type": "string", "maxLength": 512 },
        "must_match": { "type": "boolean", "default": true }
      }
    },
    "maxLength": {
      "type": "object",
      "required": ["type", "chars"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "max_length" },
        "chars": { "type": "integer", "minimum": 1, "maximum": 100000 }
      }
    },
    "jsonSchema": {
      "type": "object",
      "required": ["type", "schema"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "json_schema" },
        "schema": { "type": "object" }
      }
    },
    "toolCall": {
      "type": "object",
      "required": ["type", "name"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "tool_call" },
        "name": { "type": "string", "maxLength": 128 },
        "args_schema": { "type": "object" }
      }
    },
    "refusal": {
      "type": "object",
      "required": ["type", "expected"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "refusal" },
        "expected": { "type": "boolean" }
      }
    },
    "noPiiPatterns": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "no_pii_patterns" },
        "patterns": {
          "type": "array",
          "items": { "type": "string", "maxLength": 128 }
        }
      }
    },
    "llmJudge": {
      "type": "object",
      "required": ["type", "rubric", "min_score"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "llm_judge" },
        "rubric": { "type": "string", "maxLength": 2048 },
        "min_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "judge_model": { "type": "string", "maxLength": 128 }
      }
    }
  }
}
