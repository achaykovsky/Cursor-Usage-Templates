{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LlmJudgeCalibration",
  "type": "object",
  "required": ["schema_version", "calibration_id", "judge_model", "rubric", "samples"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "integer", "minimum": 1 },
    "calibration_id": { "type": "string", "pattern": "^[a-z][a-z0-9-]{2,63}$" },
    "judge_model": { "type": "string", "maxLength": 128 },
    "rubric": { "type": "string", "maxLength": 2048 },
    "recommended_min_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "samples": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "required": ["id", "response", "human_pass"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "maxLength": 64 },
          "response": { "type": "string", "maxLength": 8192 },
          "human_pass": { "type": "boolean" },
          "judge_score": { "type": "number", "minimum": 0, "maximum": 1 },
          "notes": { "type": "string", "maxLength": 512 }
        }
      }
    }
  }
}
